{
  "name": "@sourcifyeth/clear-signing",
  "version": "0.1.0",
  "description": "Ethereum clear signing library for human-readable transaction previews",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ethereum",
    "clear-signing",
    "eip-7730",
    "eip-712",
    "transaction",
    "wallet"
  ],
  "license": "MIT",
  "dependencies": {
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
